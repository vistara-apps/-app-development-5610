# StableSwap Scout Environment Configuration

# API Keys
VITE_BITQUERY_API_KEY=your_bitquery_api_key_here
VITE_QUICKNODE_RPC_URL=https://your-quicknode-endpoint.base-mainnet.quiknode.pro/your-api-key/
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Alternative RPC URLs (fallbacks)
VITE_ANKR_RPC_URL=https://rpc.ankr.com/base
VITE_PUBLIC_RPC_URL=https://mainnet.base.org

# Application Configuration
VITE_APP_NAME=StableSwap Scout
VITE_APP_VERSION=1.0.0
VITE_ENVIRONMENT=development

# Feature Flags
VITE_ENABLE_REAL_DATA=false
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_REPORTING=false

# Cache Configuration
VITE_PRICE_CACHE_TIMEOUT=30000
VITE_LIQUIDITY_CACHE_TIMEOUT=60000

# DEX Configuration
VITE_DEFAULT_SLIPPAGE=0.5
VITE_MAX_SLIPPAGE=5.0
VITE_GAS_MULTIPLIER=1.2

# Payment Configuration
VITE_PAYMENT_API_URL=https://payments.vistara.dev
VITE_TRADE_FEE=0.001

# Monitoring & Analytics
VITE_SENTRY_DSN=your_sentry_dsn_here
VITE_MIXPANEL_TOKEN=your_mixpanel_token_here

# Development Settings
VITE_DEBUG_MODE=true
VITE_MOCK_DATA=true
VITE_LOG_LEVEL=debug
